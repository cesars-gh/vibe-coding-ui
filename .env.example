ANTHROPIC_API_KEY=your-api-key-here

# Website repo to clone at runtime (required)
WEBSITE_REPO_URL=https://github.com/your-org/your-website-repo.git

# Branch to clone/checkout (default: main)
# WEBSITE_REPO_BRANCH=main

# Local directory for the cloned workspace (default: ./workspace)
# WEBSITE_WORKSPACE_DIR=./workspace

# GitHub PAT for HTTPS push auth (optional, injected into remote URL)
# WEBSITE_GIT_TOKEN=ghp_xxxxxxxxxxxx
